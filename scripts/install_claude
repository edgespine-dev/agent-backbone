#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

case " $* " in
  *" --profile "*|*" --list-profiles "*|*" -h "*|*" --help "*)
    exec "$script_dir/claude_install.sh" "$@"
    ;;
esac

exec "$script_dir/claude_install.sh" --profile team-default "$@"
